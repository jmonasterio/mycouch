# ============================================================
# COUCHDB NOSTR PROXY - ENVIRONMENT CONFIGURATION
# ============================================================
# IMPORTANT: Never commit this file to version control.
# Copy this file to .env and fill in the actual values.
# ============================================================

# ============================================================
# NOSTR NIP-98 SESSION AUTH
# ============================================================

# Session token secret — REQUIRED
# Used to sign HMAC-SHA256 session tokens issued after NIP-98 authentication.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters. Keep secret.
SESSION_SECRET=replace_me_with_a_real_secret_of_at_least_32_chars

# Session TTL in seconds (default: 28800 = 8 hours)
SESSION_TTL_SECONDS=28800

# NIP-98 timestamp tolerance in seconds (default: 60)
# How many seconds of clock skew to allow in Nostr signed events.
NIP98_TIME_TOLERANCE=60

# Application identifier — used as applicationId in tenant documents
# Set to the database name this deployment serves (e.g. roady, roady-staging)
APPLICATION_ID=roady

# ============================================================
# COUCHDB CONFIGURATION
# ============================================================

# Internal CouchDB URL (not exposed to public, only for proxy)
# For local Docker: http://localhost:5984
COUCHDB_INTERNAL_URL=http://localhost:5984

# CouchDB credentials for proxy authentication
COUCHDB_USER=admin
COUCHDB_PASSWORD=admin

# Couch-sitter database for user and tenant management
COUCH_SITTER_DB_URL=http://localhost:5984/couch-sitter

# Couch-sitter-log database for auth audit logging (optional)
# If not set, auth logging is disabled
COUCH_SITTER_LOG_DB_URL=http://localhost:5984/couch-sitter-log

# User cache TTL in seconds (default: 300)
USER_CACHE_TTL_SECONDS=300

# ============================================================
# PROXY SERVER CONFIGURATION
# ============================================================

# Listen IP (0.0.0.0 = all interfaces)
PROXY_HOST=0.0.0.0

# Listen port (CouchDB is 5984, proxy uses 5985)
PROXY_PORT=5985

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================
# MULTI-TENANT CONFIGURATION
# ============================================================

# Document field name for tenant isolation
TENANT_FIELD=tenant_id
